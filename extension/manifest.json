{
  "manifest_version": 3,
  "name": "Avaliador AMAWeb - Extensão",
  "version": "1.0",
  "description": "Avaliação visual de acessibilidade web baseada nas normas WCAG e NBR 17225.",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Abrir Avaliador AMAWeb"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}